#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

if ! terraform output -json all_guests >/dev/null 2>&1; then
  echo "ERROR: terraform output not available. Run 'terraform init && terraform apply' first."
  exit 2
fi

guests_json="$(terraform output -json all_guests)"
fail=0
ok=0

# Iterate name → { kind, vmid, expected_ip }
while IFS=$'\t' read -r name kind vmid expected; do
  [[ -z "$name" ]] && continue

  # Resolve actual IP via arp. If the host is unreachable, arp returns nothing.
  actual="$(arp -n "$expected" 2>/dev/null | awk 'NR>1 {print $1, $3}' | head -1)"

  if ping -c 1 -W 1 "$expected" >/dev/null 2>&1; then
    if arp -n "$expected" 2>/dev/null | tail -n +2 | grep -qi "$(printf '%02s' 0 | tr ' ' '0')"; then
      : # arp entry exists; trust expected_ip
    fi
    echo "OK    $name ($kind $vmid) → $expected"
    ok=$((ok+1))
  else
    echo "FAIL  $name ($kind $vmid): expected $expected, but host is unreachable"
    fail=$((fail+1))
  fi
done < <(echo "$guests_json" | jq -r '
    to_entries[]
    | "\(.key)\t\(.value.kind)\t\(.value.vmid)\t\(.value.expected_ip)"
')

echo
if [[ "$fail" -gt 0 ]]; then
  echo "Sentinel: $ok OK, $fail FAILED. Check router or update expected_ip in tfvars."
  exit 1
fi
echo "Sentinel: all $ok guests reachable at expected IPs."
