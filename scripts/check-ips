#!/usr/bin/env bash
# Sentinel: verify each guest is reachable at its expected_ip (from tfvars).
# Drift detection only — Terraform can't fix this (router owns the IP).
set -euo pipefail
cd "$(dirname "$0")/.."

guests=$($(which terraform) -chdir=terraform output -json all_guests 2>/dev/null) || {
  echo "ERROR: terraform output not available. Run 'terraform apply' first."; exit 2; }

fail=0
echo "$guests" | jq -r 'to_entries[] | "\(.key)\t\(.value.kind)\t\(.value.vmid)\t\(.value.expected_ip)"' |
while IFS=$'\t' read -r name kind vmid ip; do
  if ping -c1 -W1 "$ip" >/dev/null 2>&1; then
    echo "OK    $name ($kind $vmid) -> $ip"
  else
    echo "FAIL  $name ($kind $vmid): $ip unreachable"; fail=1
  fi
done

[[ $fail -eq 0 ]] && echo "All guests at expected IPs."
exit $fail
