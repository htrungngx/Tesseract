# Tesseract — environment variables for local Terraform runs.
#
# Copy to `.env` and fill in real values. `.env` is gitignored (see ADR-0009).
# Source before running terraform:
#     set -a; . ./.env; set +a
# or use direnv (a committed .envrc can do this automatically).

# --- Proxmox API (provider auth — see ADR-0002) ---
# bpg/proxmox uses PROXMOX_VE_* env vars. NOTE: PM_* vars are from the legacy
# Telmate provider and do not work here.
# The token is a single combined string: user@realm!tokenid=secret
PROXMOX_VE_ENDPOINT=https://192.168.1.21:8006
PROXMOX_VE_API_TOKEN=root@pam!terraform=REPLACE_WITH_TOKEN_SECRET
# pve01 uses a self-signed cert; set true unless a real cert is installed.
PROXMOX_VE_INSECURE=true

# --- R2 state backend (see ADR-0003) ---
# Create a bucket named tesseract-tfstate in Cloudflare R2, enable versioning,
# and mint a token scoped to this bucket. Put the values here.
AWS_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
# R2 S3 endpoint — replace <accountid> with your Cloudflare account tag.
AWS_ENDPOINT_URL_S3=https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_REGION=auto
