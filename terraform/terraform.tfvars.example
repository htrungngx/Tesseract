# Copy to terraform.tfvars (gitignored). Secrets go in .env, never here.
# Map keys are state identity — renaming = destroy + recreate.

node_name   = "pve01"
tags_global = ["iac"]

lxcs = {
  cloudflared = {
    vmid          = 100
    expected_ip   = "192.168.1.123"
    description   = "Cloudflare tunnel"
    os_template   = "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
    os_type       = "debian"
    cores         = 1
    memory_mb     = 512
    disk_gb       = 2
    tags          = ["ingress"]
  }
  adguard = {
    vmid          = 101
    expected_ip   = "192.168.1.125"
    description   = "DNS/ad-block, protected"
    os_template   = "local:vztmpl/alpine-3.23-default_20260116_amd64.tar.xz"
    os_type       = "alpine"
    cores         = 1
    memory_mb     = 512
    disk_gb       = 2
    tags          = ["dns", "protected"]
  }
  hermesagent = {
    vmid          = 102
    expected_ip   = "192.168.1.126"
    description   = "Runs this agent"
    os_template   = "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
    os_type       = "debian"
    cores         = 2
    memory_mb     = 4096
    disk_gb       = 20
    tags          = ["agent"]
  }
  cloudflare-ddns = {
    vmid          = 103
    expected_ip   = "192.168.1.127"
    description   = "DDNS updater"
    os_template   = "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
    os_type       = "debian"
    cores         = 2
    memory_mb     = 1024
    disk_gb       = 3
    tags          = ["network"]
  }
  prowlarr = {
    vmid          = 109
    expected_ip   = "192.168.1.133"
    description   = "Indexer manager"
    os_template   = "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
    os_type       = "debian"
    cores         = 2
    memory_mb     = 1024
    disk_gb       = 4
    tags          = ["media"]
  }
  radarr = {
    vmid          = 110
    expected_ip   = "192.168.1.134"
    description   = "Movie automation"
    os_template   = "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
    os_type       = "debian"
    cores         = 2
    memory_mb     = 1024
    disk_gb       = 4
    tags          = ["media"]
  }
  sonarr = {
    vmid          = 111
    expected_ip   = "192.168.1.135"
    description   = "TV automation"
    os_template   = "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
    os_type       = "debian"
    cores         = 2
    memory_mb     = 1024
    disk_gb       = 4
    tags          = ["media"]
  }
  jellyfin = {
    vmid          = 112
    expected_ip   = "192.168.1.136"
    description   = "Media server"
    os_template   = "local:vztmpl/ubuntu-24.04-standard_24.04-2_amd64.tar.zst"
    os_type       = "ubuntu"
    cores         = 2
    memory_mb     = 2048
    disk_gb       = 16
    tags          = ["media"]
    # GPU passthrough for hardware transcoding. Without this, Jellyfin falls
    # back to CPU transcoding (much slower, more power). Device paths match
    # the Intel/AMD iGPU on pve01; gid/uid/mode match what the community-script
    # set up. Verify with `lxc config show 112` on pve01 if these change.
    device_passthroughs = [
      { path = "/dev/dri/renderD128", gid = 993, mode = "0660" },
      { path = "/dev/dri/card0",      gid = 44,  mode = "0660" },
    ]
  }
  beszel = {
    vmid          = 113
    expected_ip   = "192.168.1.137"
    description   = "Monitoring hub"
    os_template   = "local:vztmpl/debian-13-standard_13.1-2_amd64.tar.zst"
    os_type       = "debian"
    cores         = 1
    memory_mb     = 512
    disk_gb       = 5
    tags          = ["monitoring"]
  }
}

# VM keys use hyphens (not underscores) — Proxmox enforces DNS naming on `name`.

vms = {
  "k3s-master01" = {
