# --- VMs --------------------------------------------------------------------
# Modeled as standalone — no clone block, no template_id (ADR-0008).
# Verify each os_template path with `pveam list local` on the host before
# copying this example to terraform.tfvars — the paths below are guesses
# based on the operator inventory and may not match what's actually downloaded.

vms = {
  k3s_master01 = {
    vmid          = 105
    expected_ip   = "192.168.1.129"
    description   = "k3s control-plane"
    cores         = 2
    memory_mb     = 4096
    disk_gb       = 20
    tags          = ["k3s", "control-plane"]
